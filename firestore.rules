rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Users can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users can write their own document, but cannot modify has_purchased
      // (only the server-side Cloud Function with Admin SDK can change it)
      allow write: if request.auth != null && request.auth.uid == userId &&
                     (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['has_purchased']));
      // Allow create (first-time user document) without restriction on has_purchased
      allow create: if request.auth != null && request.auth.uid == userId;
      
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /daily_logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Secure check for phone existence
    match /phone_registry/{phoneId} {
      // Allow unauthenticated users to check if a SPECIFIC phone exists (required for sign-up flow)
      allow get: if true;
      // Deny enumerating/scraping the entire collection
      allow list: if false;
      // Only allow writing your OWN phone number (matches auth phone number)
      allow create: if request.auth != null &&
                      phoneId == request.auth.token.phone_number;
      // Deny updates/deletes from client
      allow update, delete: if false;
    }
  }
}
